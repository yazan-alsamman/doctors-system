# Dev: leave VITE_API_BASE_URL unset so the app calls /api on the Vite dev server (see vite.config.js proxy).
VITE_DEV_PROXY_TARGET=http://127.0.0.1:3000

# Demo tenant — match your Nest prisma seed if used.
VITE_TENANT_ID=11111111-1111-1111-1111-111111111111

# Optional: call API directly in dev (restart `npm run dev` after change).
# VITE_API_BASE_URL=http://127.0.0.1:3000/api

# Production build (Hostinger): must end with /api — same value as config.json apiBase.
# VITE_API_BASE_URL=https://your-api-host.example.com/api

# GEMINI_API_KEY=
