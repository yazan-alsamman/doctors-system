# Dev: leave VITE_API_BASE_URL unset so the app calls /api on the Vite dev server, which proxies to Nest.
# If Nest prints "Using 3001" (port 3000 busy), point the proxy at that port:
VITE_DEV_PROXY_TARGET=http://127.0.0.1:3001

# Demo tenant — must match Medi_BackEnd prisma/seed.ts (run `npm run prisma:seed` in the backend once).
VITE_TENANT_ID=11111111-1111-1111-1111-111111111111

# Alternative: bypass proxy and call API directly (then restart `npm run dev`):
# VITE_API_BASE_URL=http://localhost:3001/api
GEMINI_API_KEY=AIzaSyCc_Gn5GNkTlLhSZgeb4DSUv2aqk5kQ6Zo