{
  "name": "mediflow",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "dark:audit": "node ./scripts/dark-mode-audit.mjs",
    "electron:dev": "concurrently -k -n VITE,ELECTRON -c blue,green \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:preview": "vite build --mode electron && electron .",
    "electron:build": "vite build --mode electron && electron-builder --win",
    "electron:build:all": "vite build --mode electron && electron-builder --win --mac --linux"
  },
  "build": {
    "appId": "com.mediflow.clinic",
    "productName": "MediFlow",
    "copyright": "Copyright © 2025 MediFlow",
    "asar": true,
    "directories": {
      "buildResources": "build",
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/main.cjs",
      "electron/preload.cjs",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MediFlow"
    },
    "mac": {
      "category": "public.app-category.medical",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icons",
      "category": "Office"
    }
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@heroicons/react": "^2.2.0",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dexie": "^4.4.2",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lottie-react": "^2.4.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "stylis": "^4.4.0",
    "stylis-plugin-rtl": "^2.1.1",
    "xlsx": "^0.18.5"
  },
  "overrides": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.5.11",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.10",
    "wait-on": "^8.0.0"
  },
  "optionalDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^26.0.0"
  }
}
